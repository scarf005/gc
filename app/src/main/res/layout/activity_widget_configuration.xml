<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/handleInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/field_background"
            android:gravity="top|start"
            android:hint="@string/widget_handle_hint"
            android:inputType="textMultiLine|textNoSuggestions"
            android:minHeight="96dp"
            android:minLines="3"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <Switch
            android:id="@+id/startOnSundaySwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/widget_start_on_sunday"
            android:textColor="@color/text_primary" />

        <ImageView
            android:id="@+id/previewGraph"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/widget_background"
            android:contentDescription="@string/widget_graph_content_description"
            android:padding="6dp"
            android:scaleType="centerInside" />

        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/widget_save" />

    </LinearLayout>

</ScrollView>
